#include <WiFi.h>
#include <PubSubClient.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include "DHT.h"
#include <ArduinoJson.h>

// ===== WIFI =====
const char* ssid = "iPhone";
const char* password = "Nanongunguoi123@";

// ===== MQTT =====
const char* mqtt_server = "broker.emqx.io";
WiFiClient espClient;
PubSubClient client(espClient);

// ===== OLED =====
Adafruit_SSD1306 display(128, 64, &Wire, -1);

// ===== DHT =====
#define DHTPIN 15
#define DHTTYPE DHT11
DHT dht(DHTPIN, DHTTYPE);

// ===== SENSOR =====
#define SOIL_PIN 39
#define LDR_PIN 34

// ===== RELAY =====
#define PUMP 27
#define FAN 14

// ===== LED =====
#define GREEN 26
#define RED 25
#define YELLOW 33

// ===== BUZZER =====
#define BUZZER 12

float temp = 0;
int soilPercent = 0;
int lightValue = 0;

// ===== MODE =====
String mode = "auto";

bool mqttOK = false;

// ===== SETUP WIFI =====
void setup_wifi() {
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected");
}

// ===== MQTT CALLBACK =====
void callback(char* topic, byte* payload, unsigned int length) {

  String msg = "";
  for (int i = 0; i < length; i++) {
    msg += (char)payload[i];
  }

  String t = String(topic);
  Serial.println(t + " -> " + msg);

  // ===== MODE =====
  if (t == "garden/mode") {
    mode = msg;
  }

  // ===== MANUAL MODE =====
  if (mode == "manual") {

    if (t == "garden/pump") {
      digitalWrite(PUMP, msg == "1" ? LOW : HIGH);
    }

    if (t == "garden/fan") {
      digitalWrite(FAN, msg == "1" ? LOW : HIGH);
    }

    if (t == "garden/led_green") {
      digitalWrite(GREEN, msg == "1" ? HIGH : LOW);
    }

    if (t == "garden/led_red") {
      digitalWrite(RED, msg == "1" ? HIGH : LOW);
    }

    if (t == "garden/led_yellow") {
      digitalWrite(YELLOW, msg == "1" ? HIGH : LOW);
    }

    if (t == "garden/buzzer") {
      digitalWrite(BUZZER, msg == "1" ? HIGH : LOW);
    }
  }
}

// ===== MQTT RECONNECT =====
void reconnect() {
  while (!client.connected()) {
    String clientId = "ESP32-" + String(random(0xffff), HEX);
    if (client.connect(clientId.c_str())) {
      mqttOK = true;

      client.subscribe("garden/pump");
      client.subscribe("garden/fan");
      client.subscribe("garden/mode");

      client.subscribe("garden/led_green");
      client.subscribe("garden/led_red");
      client.subscribe("garden/led_yellow");

      client.subscribe("garden/buzzer");

    } else {
      mqttOK = false;
      delay(2000);
    }
  }
}

// ===== SEND JSON SENSOR DATA =====
void sendSensorJSON() {
  StaticJsonDocument<200> doc;
  doc["temp"] = temp;
  doc["soil"] = soilPercent;
  doc["light"] = lightValue;

  char buffer[256];
  serializeJson(doc, buffer);

  // Gửi lên MQTT
  client.publish("garden/sensor", buffer);

  // Hiển thị trên Serial
  Serial.println(buffer);
}

// ===== SETUP =====
void setup() {

  Serial.begin(115200);
  Wire.begin(21, 22);
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.setTextSize(1);
  display.setTextColor(WHITE);

  pinMode(PUMP, OUTPUT);
  pinMode(FAN, OUTPUT);

  pinMode(GREEN, OUTPUT);
  pinMode(RED, OUTPUT);
  pinMode(YELLOW, OUTPUT);

  pinMode(BUZZER, OUTPUT);

  digitalWrite(PUMP, HIGH);
  digitalWrite(FAN, HIGH);
  digitalWrite(BUZZER, LOW);

  dht.begin();
  setup_wifi();

  client.setServer(mqtt_server, 1883);
  client.setCallback(callback);
}

// ===== LOOP =====
void loop() {

  if (!client.connected()) {
    reconnect();
  }
  client.loop();

  // ===== READ SENSOR =====
  float t = dht.readTemperature();
  if (!isnan(t)) temp = t;

  int soilRaw = analogRead(SOIL_PIN);
  soilPercent = map(soilRaw, 4095, 0, 0, 100);

  lightValue = analogRead(LDR_PIN);

  // ===== AUTO MODE =====
  if (mode == "auto") {

    // Pump auto
    if (soilPercent < 40) digitalWrite(PUMP, LOW);
    else digitalWrite(PUMP, HIGH);

    // Fan auto
    if (temp > 32) digitalWrite(FAN, LOW);
    else digitalWrite(FAN, HIGH);

    // LED logic
    if (temp >= 90 || soilPercent <= 10) { // RED
      digitalWrite(RED, HIGH);
      digitalWrite(GREEN, LOW);
    } else if (temp <= 50 && soilPercent >= 50) { // GREEN
      digitalWrite(GREEN, HIGH);
      digitalWrite(RED, LOW);
    } else { // OTHER
      digitalWrite(GREEN, LOW);
      digitalWrite(RED, LOW);
    }

    // YELLOW LED
    if (lightValue > 3500) digitalWrite(YELLOW, HIGH);
    else digitalWrite(YELLOW, LOW);

    // BUZZER
    if (temp > 50 || soilPercent < 20) digitalWrite(BUZZER, HIGH);
    else digitalWrite(BUZZER, LOW);
  }

  // ===== SEND JSON =====
  sendSensorJSON();

  // ===== OLED =====
  display.clearDisplay();
  display.setCursor(0, 0);
  display.println("SMART GARDEN");

  display.setCursor(0, 12);
  display.print("Temp: "); display.println(temp);

  display.setCursor(0, 22);
  display.print("Soil: "); display.println(soilPercent);

  display.setCursor(0, 32);
  display.print("Light: "); display.println(lightValue);

  display.setCursor(0, 44);
  display.print("Mode: "); display.println(mode);

  display.setCursor(0, 54);
  display.println(mqttOK ? "MQTT OK" : "MQTT WAIT");

  display.display();

  delay(2000);
}
